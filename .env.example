# OPENROUTER_API_KEY: Required for OpenRouter Qwen API calls.
OPENROUTER_API_KEY="sk-or-v1-..."

# HF_TOKEN: Optional Hugging Face token for Kolors virtual try-on rate limits.
HF_TOKEN=

# GROQ_API_KEY: Optional if you want to override the base Groq styling key layout
GROQ_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
